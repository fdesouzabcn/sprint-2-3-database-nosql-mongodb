{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "_id",
      "brand_name",
      "frame_type",
      "price",
      "supplier"
    ],
    "properties": {
      "_id": {
        "bsonType": "objectId",
        "description": "Unique identifier for the glasses product"
      },
      "brand_name": {
        "bsonType": "string",
        "minLength": 1,
        "maxLength": 50,
        "description": "Brand name"
      },
      "frame_type": {
        "bsonType": "string",
        "enum": ["floating", "plastic", "metallic"],
        "description": "Frame type"
      },
      "price": {
        "bsonType": "double",
        "minimum": 0.01,
        "description": "Current selling price"
      },
      "supplier":{
        "bsonType":"object",
        "required":["supplier_id","supplier_name"],
        "properties":{
          "supplier_id": {
            "bsonType": "objectId",
            "description": "Reference to suppliers collection (for magnifying glass detail)"
          },
          "supplier_name": {
            "bsonType": "string",
            "maxLength": 100,
            "description": "Supplier name"
          }
        },
        "description":"Supplier info"
      },
      "created_at": {
        "bsonType": "date",
        "description": "Document creation timestamp"
      },
      "updated_at": {
        "bsonType": "date",
        "description": "Document last update timestamp"
      }
    }
  }
}